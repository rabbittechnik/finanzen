# Copy to .env and fill in (never commit .env)
OPENAI_API_KEY=sk-...
# Optional overrides:
# DOCU_DATA_DIR=C:\Users\You\docu-data
# Railway: Volume auf /dokumente mounten — ohne DOCU_DATA_DIR nutzt die App dort automatisch inbox/, archive/, documents.db
# DOCU_LLM_CHAR_LIMIT=8000
# DOCU_LLM_TWO_PHASE=1          # Sehr lange PDFs: KI-Zusammenfassung dann Extraktion (2 API-Runden, höhere Kosten)
# DOCU_OPENAI_MODEL=gpt-4o-mini
# DOCU_CHAT_PANEL_HEIGHT=640    # Gesamthöhe (Pixel) des KI-Chat-Bereichs rechts (inkl. Eingabe)
# DOCU_CHAT_MSG_HEIGHT=430      # Optional: nur Verlauf; sonst automatisch aus Panel-Höhe
# DOCU_APP_VERSION=v1.0.0       # Optional: z. B. Git-Tag — Anzeige im Deploy / zur Orientierung
# DOCU_EMAIL_DRAFT_MODEL=gpt-4o-mini  # Optional: Modell für E-Mail-Entwürfe; ohne Eintrag wie Extraktion (DOCU_OPENAI_MODEL)

# Produktion (ASGI, PWA am Document-Root): uvicorn asgi:app --host 0.0.0.0 --port $PORT

# Optional: HTTP Basic Auth (beide setzen, sonst aus)
# DOCU_BASIC_AUTH_USER=admin
# DOCU_BASIC_AUTH_PASSWORD=geheim

# Optional: SMTP für Versand aus der App (Tab Dokumente → Aktionen)
# --- Gmail (App-Passwort unter Google-Konto anlegen, nicht das normale Passwort) ---
# DOCU_SMTP_HOST=smtp.gmail.com
# DOCU_SMTP_PORT=587
# DOCU_SMTP_USER=dein.name@gmail.com
# DOCU_SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# DOCU_SMTP_FROM=dein.name@gmail.com
# --- Anderer Anbieter ---
# DOCU_SMTP_HOST=smtp.example.com
# DOCU_SMTP_PORT=587
# DOCU_SMTP_USER=user@example.com
# DOCU_SMTP_PASSWORD=...
# DOCU_SMTP_FROM=user@example.com

# DOCU_JSON_LOGS=1
# DOCU_PWA_NOTIFY=1
# DOCU_ENABLE_OCR=1
